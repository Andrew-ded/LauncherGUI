<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:LauncherGUI.ViewModels"
        x:Class="LauncherGUI.Views.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        Width="1180"
        Height="760"
        MinWidth="920"
        MinHeight="620"
        Background="#111113"
        Title="Launcher GUI"
        SystemDecorations="BorderOnly"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="44"
        mc:Ignorable="d">

	<Window.Styles>
		<Style Selector="Button.NavButton">
			<Setter Property="Width" Value="48" />
			<Setter Property="Height" Value="48" />
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="CornerRadius" Value="8" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="HorizontalAlignment" Value="Center" />
			<Setter Property="VerticalAlignment" Value="Center" />
			<Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
			<Setter Property="RenderTransform">
				<ScaleTransform ScaleX="1" ScaleY="1" />
			</Setter>
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.16" />
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.16" />
					<DoubleTransition Property="Opacity" Duration="0:0:0.16" />
				</Transitions>
			</Setter>
		</Style>

		<Style Selector="Button.NavButton:pointerover">
			<Setter Property="Background" Value="#252935" />
			<Setter Property="RenderTransform" Value="scale(1.03)" />
		</Style>

		<Style Selector="Button.NavButton:pressed">
			<Setter Property="RenderTransform" Value="scale(0.98)" />
		</Style>

		<Style Selector="Button.NavButton.Active">
			<Setter Property="Background" Value="#2C4EA740" />
		</Style>

		<Style Selector="Button.CardMenuButton">
			<Setter Property="Width" Value="30" />
			<Setter Property="Height" Value="30" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="CornerRadius" Value="8" />
			<Setter Property="HorizontalAlignment" Value="Right" />
			<Setter Property="VerticalAlignment" Value="Top" />
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.16" />
					<DoubleTransition Property="Opacity" Duration="0:0:0.16" />
				</Transitions>
			</Setter>
		</Style>

		<Style Selector="Button.CardMenuButton:pointerover">
			<Setter Property="Background" Value="#FFFFFF" />
		</Style>

		<Style Selector="Border.AppCardBorder">
			<Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
			<Setter Property="RenderTransform">
				<ScaleTransform ScaleX="1" ScaleY="1" />
			</Setter>
			<Setter Property="Transitions">
				<Transitions>
					<TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.16" />
					<BrushTransition Property="Background" Duration="0:0:0.16" />
					<DoubleTransition Property="Opacity" Duration="0:0:0.16" />
				</Transitions>
			</Setter>
		</Style>

		<Style Selector="Border.AppCardBorder:pointerover">
			<Setter Property="RenderTransform" Value="scale(1.015)" />
			<Setter Property="Background" Value="#202026" />
		</Style>

		<Style Selector="Button.LaunchButton">
			<Setter Property="Background" Value="#2C4EA7" />
			<Setter Property="Foreground" Value="#FFFFFFE0" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="CornerRadius" Value="8" />
			<Setter Property="Padding" Value="10,6" />
			<Setter Property="HorizontalAlignment" Value="Stretch" />
		</Style>

		<Style Selector="Button.WindowControlButton">
			<Setter Property="Width" Value="36" />
			<Setter Property="Height" Value="28" />
			<Setter Property="Padding" Value="0" />
			<Setter Property="Background" Value="{DynamicResource SystemRegionBrush }" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="CornerRadius" Value="8" />
			<Setter Property="Transitions">
				<Transitions>
					<BrushTransition Property="Background" Duration="0:0:0.14" />
				</Transitions>
			</Setter>
		</Style>

		<Style Selector="Button.WindowControlButton:pointerover">
			<Setter Property="Background" Value="{DynamicResource SystemAccentColor }" />
		</Style>
	</Window.Styles>

	<Grid Background="#111113">
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="84" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>

		<Border Grid.Column="0"
				Background="#17181C"
				Padding="12,18"
				CornerRadius="0,10,10,0">
			<StackPanel Spacing="12" HorizontalAlignment="Center">
				<Button Classes="NavButton Active" ToolTip.Tip="Приложения">
					<!-- <Image 
				Source="avares://LauncherGUI2/Assets/Icons/apps.png"
				HorizontalAlignment="Center"
				VerticalAlignment="Center"
				/>-->
					<PathIcon Width="26" Height="26" Foreground="#FFFFFFE0" Data="M4 5.5A1.5 1.5 0 0 1 5.5 4h5A1.5 1.5 0 0 1 12 5.5v5a1.5 1.5 0 0 1-1.5 1.5h-5A1.5 1.5 0 0 1 4 10.5v-5Zm8 0A1.5 1.5 0 0 1 13.5 4h5A1.5 1.5 0 0 1 20 5.5v5a1.5 1.5 0 0 1-1.5 1.5h-5A1.5 1.5 0 0 1 12 10.5v-5Zm-8 8A1.5 1.5 0 0 1 5.5 12h5a1.5 1.5 0 0 1 1.5 1.5v5a1.5 1.5 0 0 1-1.5 1.5h-5A1.5 1.5 0 0 1 4 18.5v-5Zm8 0a1.5 1.5 0 0 1 1.5-1.5h5a1.5 1.5 0 0 1 1.5 1.5v5a1.5 1.5 0 0 1-1.5 1.5h-5a1.5 1.5 0 0 1-1.5-1.5v-5Z" />
				</Button>
				<Button Classes="NavButton" ToolTip.Tip="Безопасность">
					<PathIcon Width="26" Height="26" Foreground="#FFFFFFB8" Data="M12 2.5 5 5.3v5.6c0 4.1 2.5 7.8 6.3 9.1l.7.2.7-.2C16.5 18.7 19 15 19 10.9V5.3L12 2.5Zm0 2.2 5 2v4.2c0 3.3-1.9 6.2-5 7.4-3.1-1.2-5-4.1-5-7.4V6.7l5-2Z" />
				</Button>
				<Button Classes="NavButton" ToolTip.Tip="Настройки">
					<PathIcon Width="26" Height="26" Foreground="#FFFFFFB8" Data="M10.3 3.3a1 1 0 0 1 1-.8h1.4a1 1 0 0 1 1 .8l.3 1.5a7.5 7.5 0 0 1 1.2.7l1.4-.5a1 1 0 0 1 1.1.4l.7 1.2a1 1 0 0 1-.2 1.2l-1.1 1a7.7 7.7 0 0 1 0 1.4l1.1 1a1 1 0 0 1 .2 1.2l-.7 1.2a1 1 0 0 1-1.1.4l-1.4-.5a7.5 7.5 0 0 1-1.2.7l-.3 1.5a1 1 0 0 1-1 .8h-1.4a1 1 0 0 1-1-.8l-.3-1.5a7.5 7.5 0 0 1-1.2-.7l-1.4.5a1 1 0 0 1-1.1-.4l-.7-1.2a1 1 0 0 1 .2-1.2l1.1-1a7.7 7.7 0 0 1 0-1.4l-1.1-1a1 1 0 0 1-.2-1.2l.7-1.2a1 1 0 0 1 1.1-.4l1.4.5c.4-.3.8-.5 1.2-.7l.3-1.5ZM12 9a3 3 0 1 0 0 6 3 3 0 0 0 0-6Z" />
				</Button>
			</StackPanel>
		</Border>

		<Grid Grid.Column="1">
			<ScrollViewer VerticalScrollBarVisibility="Auto">
				<StackPanel Margin="32" Spacing="12">
					<TextBlock Text="Launcher GUI"
							   HorizontalAlignment="Center"
							   FontSize="24"
							   FontWeight="SemiBold"
							   Foreground="#FFFFFFE0"
							   Margin="0,6,0,4"
							   PointerPressed="TitleBar_OnPointerPressed" />

					<ItemsControl ItemsSource="{Binding Applications}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<WrapPanel Orientation="Horizontal" />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>

						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="viewModels:AppCardViewModel">
								<Border Classes="AppCardBorder"
										Width="172"
										Margin="8"
										Padding="16"
										Background="#1A1A1E"
										CornerRadius="10"
										BoxShadow="0 2 10 0 #0A000000"
										DoubleTapped="AppCard_OnDoubleTapped">
									<Grid RowDefinitions="Auto,Auto,*,Auto" RowSpacing="8">


										<Image Grid.Row="1"
											   Source="{Binding IconApp}"
											   Width="64"
											   Height="64"
											   HorizontalAlignment="Center"
											   VerticalAlignment="Center"
											   Stretch="Uniform" />

										<TextBlock Grid.Row="2"
												   Text="{Binding Name}"
												   HorizontalAlignment="Center"
												   VerticalAlignment="Center"
												   TextAlignment="Center"
												   FontSize="15"
												   FontWeight="Regular"
												   Foreground="#FFFFFFE0"
												   TextTrimming="CharacterEllipsis"
												   MaxWidth="130" />
										<Button Classes="CardMenuButton" Grid.Row="0">
											<Button.Flyout>
												<Flyout Placement="BottomEdgeAlignedRight">
													<StackPanel MinWidth="170" Spacing="8" Margin="4">
														<TextBlock Foreground="#FFFFFFE0">
															<Run Text="Версия: " />
															<Run Text="{Binding Version}" />
														</TextBlock>
														<Button Classes="LaunchButton"
																Command="{Binding $parent[Window].DataContext.LaunchApplicationCommand}"
																CommandParameter="{Binding}"
																Content="Запустить" />
														<Button Classes="LaunchButton"
															Command="{Binding $parent[Window].DataContext.DeleteApplicationCommand}"
																CommandParameter="{Binding}"
																Content="Удалить"
																Background="#df3030"/>
													</StackPanel>
												</Flyout>
											</Button.Flyout>
											<TextBlock Text="⋯" FontSize="18" Foreground="#FFFFFFB8" HorizontalAlignment="Center" VerticalAlignment="Center" />
										</Button>
										<!-- <Button Grid.Row="3"
                            Classes="LaunchButton"
                            Command="{Binding $parent[Window].DataContext.LaunchApplicationCommand}"
                            CommandParameter="{Binding}"
                            Content="Открыть" /> -->
									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>
			</ScrollViewer>

			<StackPanel Orientation="Horizontal"
						HorizontalAlignment="Right"
						VerticalAlignment="Top"
						Margin="0,8,12,0"
						Spacing="4">
				<Button Classes="WindowControlButton" Click="Minimize_OnClick">
					<TextBlock Text="—" FontSize="14" Foreground="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
				</Button>

				<Button Classes="WindowControlButton" Click="ToggleMaximize_OnClick">
					<TextBlock Text="□" FontSize="12" Foreground="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
				</Button>

				<Button Classes="WindowControlButton" Click="Close_OnClick">
					<TextBlock Text="✕" FontSize="12" Foreground="#FFFFFF" HorizontalAlignment="Center" VerticalAlignment="Center" />
				</Button>
			</StackPanel>
		</Grid>


	</Grid>
</Window>
