<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="LauncherGUI.App"
             RequestedThemeVariant="Dark">

  <Application.Styles>
    <FluentTheme>
      <FluentTheme.Palettes>
		  <ColorPaletteResources x:Key="Dark"
						 Accent="#2C4EA7"
						 RegionColor="#1E1E22"
						 BaseHigh="#FFFFFFE0"
						 BaseMedium="#FFFFFF90" />
      </FluentTheme.Palettes>
    </FluentTheme>
  </Application.Styles>
</Application>
