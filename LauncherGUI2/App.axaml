<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="LauncherGUI.App"
             RequestedThemeVariant="Dark">

  <Application.Styles>
    <!-- Глобальная Fluent-тема приложения -->
    <FluentTheme>
      <FluentTheme.Palettes>
        <!-- Кастомная палитра под темный интерфейс с синим акцентом -->
        <ColorPaletteResources x:Key="Dark"
                               Accent="#2C4EA7"
                               RegionColor="#1E1E22"
                               BaseHigh="#FFFFFF"
                               BaseMedium="#FFFFFF" />
      </FluentTheme.Palettes>
    </FluentTheme>
  </Application.Styles>
</Application>
